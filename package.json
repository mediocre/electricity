{
  "description": "An alternative to the built-in Express middleware for serving static files. Electricity follows a number of best practices for making web pages fast.",
  "dependencies": {
    "@babel/preset-env": "^7.4.5",
    "chokidar": "~3.0.0",
    "mime": "~2.4.0",
    "negotiator": "0.6.x",
    "react-tools": "0.13.x",
    "sass": "~1.20.1",
    "sass-graph": "3.0.x",
    "snockets": "1.3.x",
    "uglify-es": "3.3.x",
    "uglifycss": "0.0.x"
  },
  "devDependencies": {
    "@babel/core": "^7.4.5",
    "@babel/plugin-proposal-class-properties": "^7.4.4",
    "@babel/plugin-proposal-export-default-from": "^7.2.0",
    "@babel/plugin-transform-modules-commonjs": "^7.4.4",
    "@babel/plugin-transform-react-constant-elements": "^7.2.0",
    "@babel/plugin-transform-react-display-name": "^7.2.0",
    "@babel/plugin-transform-react-inline-elements": "^7.2.0",
    "@babel/plugin-transform-react-jsx": "^7.3.0",
    "@babel/plugin-transform-react-jsx-compat": "^7.2.0",
    "@babel/plugin-transform-react-jsx-self": "^7.2.0",
    "@babel/plugin-transform-react-jsx-source": "^7.2.0",
    "@babel/preset-react": "^7.0.0",
    "buffer-compare": "*",
    "coveralls": "*",
    "fs-extra": "*",
    "istanbul": "*",
    "mocha": "*"
  },
  "keywords": [
    "asset",
    "css",
    "express",
    "react",
    "sass",
    "static",
    "snockets"
  ],
  "main": "./lib",
  "name": "electricity",
  "repository": "git://github.com/mediocre/electricity.git",
  "scripts": {
    "coveralls": "istanbul cover ./node_modules/mocha/bin/_mocha --report lcovonly -- --exit -R spec -t 21000 && cat ./coverage/lcov.info | ./node_modules/coveralls/bin/coveralls.js && rm -rf ./coverage",
    "test": "mocha --exit -R spec -t 21000"
  },
  "version": "2.6.0"
}
